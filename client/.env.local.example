# Umami Analytics - Local Development
# Copy this file to .env.local and update with your values

# Local Umami URL (from docker-compose)
VITE_UMAMI_URL=http://localhost:3100

# Your website ID from Umami dashboard
# Get this after creating a website in Umami (http://localhost:3100)
VITE_UMAMI_WEBSITE_ID=your-website-id-here

# Auth code for admin access (already set in your backend)
VITE_AUTH_CODE=your-auth-code

# API URL for development
VITE_API_URL=http://localhost:3021
